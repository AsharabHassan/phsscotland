# Claude API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=xxxxx

# GHL Webhook URL for lead submission
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/xxxxx/webhook-trigger/xxxxx

# GHL Calendar embed URL (found in Calendars > Calendar Settings > Embed)
NEXT_PUBLIC_GHL_CALENDAR_URL=https://api.leadconnectorhq.com/widget/booking/xxxxx

# Contact phone number (digits only, no + prefix, e.g. 447911123456 for UK)
NEXT_PUBLIC_CONTACT_PHONE=447000000000
